{
	"name": "typo3/cms-base-distribution",
	"description" : "TYPO3 CMS Base Distribution",
	"license": "GPL-2.0-or-later",
	"config": {
		"allow-plugins": {
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"platform": {
			"php": "8.1"
		},
		"sort-packages": true
	},
    	"repositories": [
        	{
            		"type": "composer",
            		"url": "https://composer.typo3.org/"
        	},
        	{
            		"type": "vcs",
            		"url": "https://github.com/eduardofrank/artmediagallery12"
        	}
    	],	
	"require": {
		"eduardo-frank/artmediagallery12": "@dev",
		"georgringer/news": "^11.0",
		"helhum/typo3-console": "^8.0",
		"netresearch/rte-ckeditor-image": "*",
		"typo3/cms-adminpanel": "^12.4",
		"typo3/cms-backend": "^12.4",
		"typo3/cms-belog": "^12.4",
		"typo3/cms-beuser": "^12.4",
		"typo3/cms-core": "^12.4",
		"typo3/cms-dashboard": "^12.4",
		"typo3/cms-extbase": "^12.4",
		"typo3/cms-extensionmanager": "^12.4",
		"typo3/cms-filelist": "^12.4",
		"typo3/cms-fluid": "^12.4",
		"typo3/cms-fluid-styled-content": "^12.4",
		"typo3/cms-form": "^12.4",
		"typo3/cms-frontend": "^12.4",
		"typo3/cms-impexp": "^12.4",
		"typo3/cms-info": "^12.4",
		"typo3/cms-install": "^12.4",
		"typo3/cms-lowlevel": "^12.4",
		"typo3/cms-opendocs": "^12.4",
		"typo3/cms-recordlist": "^12.4",
		"typo3/cms-recycler": "^12.4",
		"typo3/cms-redirects": "^12.4",
		"typo3/cms-reports": "^12.4",
		"typo3/cms-rte-ckeditor": "^12.4",
		"typo3/cms-scheduler": "^12.4",
		"typo3/cms-seo": "^12.4",
		"typo3/cms-setup": "^12.4",
		"typo3/cms-tstemplate": "^12.4",
		"typo3/cms-viewpage": "^12.4",
		"yoast-seo-for-typo3/yoast_seo": "*"
	},
	"scripts":{
		"typo3-cms-scripts": [
			"typo3cms install:generatepackagestates",
			"typo3cms install:fixfolderstructure"
		],
		"post-autoload-dump": [
			"@typo3-cms-scripts"
		]
	}
}
